@page "/creator"
@using KombatFighters.Models
@using KombatFighters.Shared
@using KombatFighters.Services
@inject DeckService DeckService
@inject PdfExportService PdfService

<PageTitle>Kombat Fighters Creator</PageTitle>

<h3>Création de cartes</h3>

<div class="page-structure">
    
    <div class="menu-creator">
        <button class="global-style-card action-button" @onclick="DeselectionnerCarte">
            <p>Style général</p>
        </button>

        <div class="style-card-container">
            <button class="style-card action-button" @onclick="ToggleMenu">
                <p>Style par carte</p>
                <span class="arrow @(isMenuOpen ? "open" : "")">▼</span>
            </button>

            @if (isMenuOpen)
            {
                <div class="dropdown-content">
                    @foreach (var carte in DeckService.MesCartes)
                    {
                        <div class="type-card" @onclick="() => SelectionnerCarte(carte)">
                            <div class="describe-card">
                                <h4>@carte.Titre</h4>
                                <p>Dégâts: @carte.Degat | Énergie: @carte.Energie</p>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
        
        <button class="action-button" @onclick="GenererPDF" style="background-color: #d4edda; border-color: #c3e6cb; margin-top: 20px;">
            <p>📄 Télécharger le PDF</p>
        </button>
    </div>

    <div class="creator-view">
        <div class="form-creator">
            <div class="inner-form">
                
                @if (carteSelectionnee == null)
                {
                    <h4 style="margin-top: 0;">Paramètres globaux</h4>
                    <div class="element-form">
                        <div class="color-background" style="flex: 1;">
                            <label for="color">Couleur de fond par défaut</label><br />
                            <input class="input" type="color" name="color" @bind="couleurDeFond" @bind:event="oninput" />
                        </div>
                        <div class="recto-card" style="flex: 1;">
                            <label for="file">Image du personnage globale</label><br />
                            <InputFile class="input" OnChange="ChargerImagePersonnageGlobale" accept="image/*" />
                        </div>
                        <div class="recto-card" style="flex: 1;">
                            <label for="file">Dos de la carte (Verso global)</label><br />
                            <InputFile class="input" OnChange="ChargerImageVersoGlobale" accept="image/*" />
                        </div>
                    </div>
                }
                else
                {
                    <h4 style="margin-top: 0;">Édition de la carte</h4>
                    
                    @if (carteSelectionnee.EstSpeciale)
                    {
                        <div class="element-form" style="margin-bottom: 10px;">
                            <div style="flex: 2;">
                                <label>Nom de l'attaque :</label><br />
                                <input class="input" type="text" @bind="carteSelectionnee.Titre" @bind:event="oninput" style="width: 100%;" />
                            </div>
                            <div style="flex: 1;">
                                <label>Dégâts :</label><br />
                                <input class="input" type="number" @bind="carteSelectionnee.Degat" @bind:event="oninput" style="width: 100%;" />
                            </div>
                            <div style="flex: 1;">
                                <label>Énergie :</label><br />
                                <input class="input" type="number" @bind="carteSelectionnee.Energie" @bind:event="oninput" style="width: 100%;" />
                            </div>
                        </div>

                        <div class="element-form">
                            <div style="flex: 1;">
                                <label>Zone d'attaque (Cliquez pour modifier) :</label><br />
                                <div class="grid-editor">
                                    @for (int i = 0; i < 9; i++)
                                    {
                                        int index = i;
                                        <div class="grid-cell-edit state-@carteSelectionnee.GrilleAttaque[index]"
                                             @onclick="() => ToggleGridState(index)">
                                            @(index == 4 ? "X" : "")
                                        </div>
                                    }
                                </div>
                                <small style="color: gray;">Vide -> Attaque (Rouge)</small>
                            </div>
                            
                            <div style="flex: 1;">
                                <label>Image du personnage (Spécifique) :</label><br />
                                <InputFile class="input" OnChange="ChargerImageCarte" accept="image/*" />
                                
                                <label style="margin-top: 10px; display: block;">Couleur de fond spécifique :</label>
                                <input class="input" type="color" @bind="carteSelectionnee.CouleurFond" @bind:event="oninput" />
                            </div>
                        </div>
                    }
                    else
                    {
                        <div style="padding: 15px; text-align: center; background-color: #e9ecef; border-radius: 8px; border: 1px solid #ccc;">
                            <p style="margin-top: 0; font-weight: bold; color: #555;">Ceci est une carte standard du jeu.</p>
                            <p style="font-size: 0.9rem; color: #666; margin-bottom: 0;">
                                Ses statistiques, son nom et sa zone d'attaque sont dictés par les règles.<br />
                                Elle utilisera l'image globale du personnage définie dans le "Style général".
                            </p>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="preview">
            <h4>Aperçu en direct</h4>
            
            @if (carteSelectionnee != null)
            {
                <CarteTemplate Carte="carteSelectionnee"
                               CouleurGlobale="@couleurDeFond"
                               ImagePersonnageGlobale="@imagePersonnageGlobale"
                               ImageVersoGlobale="@imageVersoGlobale"
                               AfficherVerso="false" />
            }
            else
            {
                <div style="opacity: 0.5;">
                    <CarteTemplate Carte="new CarteInfo()"
                                   CouleurGlobale="@couleurDeFond"
                                   ImageVersoGlobale="@imageVersoGlobale"
                                   AfficherVerso="true" />
                </div>
                <p style="text-align: center; color: #666; font-style: italic; margin-top: 10px;">
                    Sélectionnez une carte pour l'éditer.
                </p>
            }
        </div>
        
    </div>
</div>

@code {
    private bool isMenuOpen = true;
    private CarteInfo? carteSelectionnee = null;
    private string couleurDeFond = "#a00000";

    // CORRECTION : Déclaration des variables manquantes pour les images globales
    private string imagePersonnageGlobale = "";
    private string imageVersoGlobale = "";

    protected override void OnInitialized()
    {
        DeckService.GenererDeckDeBase();
    }

    private void ToggleMenu() => isMenuOpen = !isMenuOpen;
    private void SelectionnerCarte(CarteInfo carte) => carteSelectionnee = carte;
    private void DeselectionnerCarte() => carteSelectionnee = null;

    private void ToggleGridState(int index)
    {
        if (carteSelectionnee != null && carteSelectionnee.EstSpeciale)
        {
            carteSelectionnee.GrilleAttaque[index] = carteSelectionnee.GrilleAttaque[index] == 0 ? 1 : 0;
        }
    }

    // --- Les 3 méthodes d'upload d'images ---

    // 1. Pour l'image spécifique d'une carte (les attaques spéciales)
    private async Task ChargerImageCarte(InputFileChangeEventArgs e)
    {
        if (e.File != null && carteSelectionnee != null && carteSelectionnee.EstSpeciale)
        {
            var image = await e.File.RequestImageFileAsync(e.File.ContentType, 600, 600);
            var buffer = new byte[image.Size];
            await image.OpenReadStream(maxAllowedSize: 1024 * 1024 * 5).ReadAsync(buffer);
            carteSelectionnee.ImageUrl = $"data:{e.File.ContentType};base64,{Convert.ToBase64String(buffer)}";
        }
    }

    // 2. Pour l'image du personnage globale (le style général)
    private async Task ChargerImagePersonnageGlobale(InputFileChangeEventArgs e)
    {
        if (e.File != null)
        {
            var image = await e.File.RequestImageFileAsync(e.File.ContentType, 600, 600);
            var buffer = new byte[image.Size];
            await image.OpenReadStream(maxAllowedSize: 1024 * 1024 * 5).ReadAsync(buffer);
            imagePersonnageGlobale = $"data:{e.File.ContentType};base64,{Convert.ToBase64String(buffer)}";
        }
    }

    // 3. Pour le dos de la carte (le verso global)
    private async Task ChargerImageVersoGlobale(InputFileChangeEventArgs e)
    {
        if (e.File != null)
        {
            var image = await e.File.RequestImageFileAsync(e.File.ContentType, 600, 600);
            var buffer = new byte[image.Size];
            await image.OpenReadStream(maxAllowedSize: 1024 * 1024 * 5).ReadAsync(buffer);
            imageVersoGlobale = $"data:{e.File.ContentType};base64,{Convert.ToBase64String(buffer)}";
        }
    }

    private async Task GenererPDF()
    {
        await PdfService.ExporterDeckEnPdf(DeckService.MesCartes);
    }
}